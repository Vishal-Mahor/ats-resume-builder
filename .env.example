NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_EXPIRES=1h
JWT_REFRESH_EXPIRES=24h

# Turso Cloud example:
# TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
#
# Local libSQL/SQLite fallback for quick development:
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# SMTP email verification
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SUPPORT_INBOX_EMAIL=

# Twilio SMS verification
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
# Optional fallback for local numbers without +country code (example: +91)
TWILIO_DEFAULT_COUNTRY_CODE=

# Razorpay billing (Plus plan checkout)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Set to true only when you have filled the matching provider keys below.
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=false

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
