NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-a-long-random-string

# Turso Cloud example:
# TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
#
# Local libSQL/SQLite fallback for quick development:
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Set to true only when you have filled the matching provider keys below.
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=false

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
